# API keys for the LUMEN monitoring test rig.
#
#   cp .env.example .env      # .env is gitignored - keys never reach git
#
# Fill in the providers you want to exercise and leave the rest EMPTY or
# delete the line: the gateway reads a key only when a request routes to that
# provider, and the smoke suite skips providers whose key is missing.
#
# After editing, re-create the gateway container so it sees the new values:
#   docker compose up -d lumen

# --- Chat ------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# --- Embeddings / reranking ------------------------------------------------
COHERE_API_KEY=
JINA_API_KEY=
VOYAGE_API_KEY=

# --- Cloudflare Workers AI ---------------------------------------------------
# Needs TWO things:
#   1. this API token (create one with the "Workers AI - Read" permission)
#   2. your account id pasted into monitoring/lumen.toml (the cloudflare
#      provider's base_url embeds it - search for YOUR_CLOUDFLARE_ACCOUNT_ID)
CLOUDFLARE_API_TOKEN=
