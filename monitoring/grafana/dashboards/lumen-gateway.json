    {
      "type": "state-timeline",
      "title": "Circuit breaker state (provider / model)",
      "description": "0 = closed (healthy), 1 = open (failing, requests skip to fallback), 2 = half-open (probing).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "lumen_circuit_state or label_replace(label_replace(vector(0), \"provider\", \"all\", \"\", \"\"), \"model\", \"circuits\", \"\", \"\")",
          "legendFormat": "{{provider}} / {{model}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Closed",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Open",
                  "color": "red",
                  "index": 1
                },
                "2": {
                  "text": "Half-open",
                  "color": "yellow",
                  "index": 2
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "stat",
      "title": "Provider health (probed base_url only)",
      "description": "Background health checks probe providers with an explicit base_url (here: Cloudflare). Vendors on built-in URLs are never probed.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 30
