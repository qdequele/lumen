{
  "uid": "lumen-gateway",
  "title": "LUMEN Gateway",
  "description": "Token consumption, per-provider usage, rerank/media accounting and resilience for the LUMEN gateway (metrics from /metrics, ADR 003).",
  "tags": [
    "lumen"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "5s",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "Tokens (range)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(lumen_tokens_total[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#0072B2"
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
