      "panels": []
    },
    {
      "type": "timeseries",
      "title": "API latency by endpoint (p50 / p99)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "range": true,
          "expr": "histogram_quantile(0.99, sum by (le, path) (rate(lumen_http_request_duration_seconds_bucket{path=~\"/v1/.*\"}[$__rate_interval])))",
          "legendFormat": "p99 {{path}}"
        },
        {
          "refId": "B",
          "range": true,
          "expr": "histogram_quantile(0.50, sum by (le, path) (rate(lumen_http_request_duration_seconds_bucket{path=~\"/v1/.*\"}[$__rate_interval])))",
          "legendFormat": "p50 {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "p50 .*"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    6,
                    4
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "lumen_http_request_duration_seconds: every HTTP request, labelled with the matched route template. Includes upstream model time for /v1/* calls."
    },
