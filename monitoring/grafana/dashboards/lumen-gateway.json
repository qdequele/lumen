{
  "uid": "lumen-gateway",
  "title": "LUMEN Gateway",
  "description": "Token consumption, latency, per-provider usage, rerank/media accounting, multi-tenant attribution and resilience for the LUMEN gateway.",
  "tags": [
    "lumen"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "5s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(lumen_tokens_total, provider)",
          "refId": "var-provider"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": []
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(lumen_tokens_total{provider=~\"$provider\"}, model)",
          "refId": "var-model"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": []
      },
      {
        "name": "org_id",
        "label": "Org",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(lumen_tokens_total, org_id)",
          "refId": "var-org_id"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": []
      },
      {
        "name": "scenario",
        "label": "Scenario",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(lumen_tokens_total, scenario)",
          "refId": "var-scenario"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Tokens (range)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(lumen_tokens_total{provider=~\"$provider\",model=~\"$model\",org_id=~\"$org_id\",scenario=~\"$scenario\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "color": {
            "mode": "fixed",
            "fixedColor": "#0072B2"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "value"
      }
    },
    {
