    {
      "type": "stat",
      "title": "Locally estimated share",
      "description": "Share of tokens counted by the local estimator instead of upstream usage (ADR 003). 0% = every upstream reported usage.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(increase(lumen_tokens_total{estimated=\"true\"}[$__range])) or vector(0)) / clamp_min(sum(increase(lumen_tokens_total[$__range])), 1)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "orange",
                "value": 60
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "value"
      }
    },
